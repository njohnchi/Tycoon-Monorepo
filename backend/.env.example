# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_DEFAULT_VERSION=1
API_ENABLE_LEGACY_UNVERSIONED=true
API_LEGACY_UNVERSIONED_SUNSET=

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tycoon_db
# Local dev only. Ignored when NODE_ENV=production|provision. Production uses migrations only.
DB_SYNCHRONIZE=false
DB_LOGGING=true

# --- Connection Pool ---
# DB_POOL_SIZE: max open connections per app instance.
#   Local default: 5  (small; avoids exhausting a dev Postgres container)
#   RDS default:   20 (db.t3.medium has max_connections ~100; leave headroom for replicas)
# DB_POOL_SIZE=5

# DB_POOL_IDLE_TIMEOUT_MS: ms before an idle connection is closed.
#   Local default: 10000
#   RDS default:   30000  (must be < RDS idle_client_timeout 600 000 ms)
# DB_POOL_IDLE_TIMEOUT_MS=10000

# DB_STATEMENT_TIMEOUT_MS: hard limit on any single statement (0 = disabled).
#   Local default: 0  (disabled; useful for long seed/migration scripts)
#   RDS default:   30000  (kills runaway queries before they hold locks)
# DB_STATEMENT_TIMEOUT_MS=0

# DB_CONNECT_TIMEOUT_MS: how long to wait for a connection from the pool.
#   Default: 5000 (both local and RDS)
# DB_CONNECT_TIMEOUT_MS=5000

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION_TIME=1d
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Clock skew tolerance in seconds (default: 60)
# Allows tokens to be valid within this time window to account for clock differences
JWT_CLOCK_SKEW_SECONDS=60

# CORS Configuration
# CORS_ALLOWED_ORIGINS - Comma-separated list of allowed origins
# Examples:
#   Development: http://localhost:3000,http://localhost:3001
#   Production: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# CORS_CREDENTIALS - Enable credentials (cookies, authorization headers)
# Default: true
# Note: Cannot use wildcard (*) origin when credentials are enabled
CORS_CREDENTIALS=true

# CORS_MAX_AGE - Preflight cache duration in seconds (Access-Control-Max-Age)
# Default: 86400 (24 hours)
# Reduces preflight requests by caching CORS policy
CORS_MAX_AGE=86400

# CORS_DEV_WILDCARD - Enable development wildcard rules
# Default: true
# When enabled in development, automatically allows:
#   - localhost (any port)
#   - 127.0.0.1 (any port)
#   - *.local domains
# Set to false to enforce strict allowlist even in development
CORS_DEV_WILDCARD=true

# Legacy CORS Configuration (deprecated, use CORS_ALLOWED_ORIGINS instead)
# CORS_ORIGIN - Single origin (backward compatibility)
# If CORS_ALLOWED_ORIGINS is not set, this will be used
# CORS_ORIGIN=http://localhost:3000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# Logging Configuration
# LOG_LEVEL - Available levels: error, warn, info, http, verbose, debug, silly
# Default: debug (development), info (production), error (test)
LOG_LEVEL=debug

# LOG_CONSOLE - Enable console logging in production (default: false)
# Useful for containerized environments where logs are collected from stdout
LOG_CONSOLE=false
