{
  "name": "shop-admin-backend",
  "version": "1.0.0",
  "description": "Admin CRUD for shop items",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
